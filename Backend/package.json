{
    "name": "finance-dashboard-api",
    "version": "1.0.0",
    "description": "Production-grade Finance Dashboard REST API",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "lint": "eslint . --ext .ts",
        "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
        "test": "jest --runInBand --forceExit",
        "test:unit": "jest --testPathPattern=tests/unit --runInBand",
        "test:integration": "jest --testPathPattern=tests/integration --runInBand --forceExit",
        "test:coverage": "jest --coverage --runInBand --forceExit",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:deploy": "prisma migrate deploy",
        "prisma:seed": "ts-node prisma/seed.ts",
        "prisma:studio": "prisma studio",
        "test:smoke": "npx ts-node scripts/smoke-test.ts"
    },
    "dependencies": {
        "@prisma/client": "5.22.0",
        "bcrypt": "^5.1.1",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "env-var": "^7.4.1",
        "express": "^4.18.3",
        "express-rate-limit": "^7.2.0",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "winston": "^3.13.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.14",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/mocha": "^10.0.10",
        "@types/morgan": "^1.9.9",
        "@types/node": "^20.11.25",
        "@types/supertest": "^6.0.2",
        "@typescript-eslint/eslint-plugin": "^7.2.0",
        "@typescript-eslint/parser": "^7.2.0",
        "eslint": "^8.57.0",
        "jest": "^29.7.0",
        "prettier": "^3.2.5",
        "prisma": "5.22.0",
        "supertest": "^6.3.4",
        "ts-jest": "^29.1.2",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.4.2"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    }
}
